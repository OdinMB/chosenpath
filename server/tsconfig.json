{
  "extends": "../tsconfig.json",
  "compilerOptions": {
    "outDir": "./dist",
    "rootDir": "src",
    "baseUrl": "src",
    "paths": {
      "core/*": ["../../core/*"],
      "server/*": ["./*"],
      "routes/*": ["./routes/*"],
      "shared/*": ["./shared/*"],
      "admin/*": ["./admin/*"],
      "game/*": ["./game/*"],
      "page/*": ["./page/*"],
      "user/*": ["./user/*"]
    },
    "strict": true,
    "strictNullChecks": true,
    "strictPropertyInitialization": true,
    "useUnknownInCatchVariables": false,
    "strictFunctionTypes": true,
    "noImplicitAny": false,
    "noImplicitThis": false,
    "alwaysStrict": false,
    "types": ["node"]
  },
  "references": [{ "path": "../core" }],
  "include": ["src/**/*", "src/**/*.test.ts", "src/__tests__/*.d.ts"],
  "exclude": ["node_modules", "dist"]
}
