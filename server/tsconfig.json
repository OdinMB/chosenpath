{
  "extends": "../tsconfig.json",
  "compilerOptions": {
    "outDir": "./dist",
    "rootDir": "..",
    "baseUrl": "..",
    "composite": true,
    "declaration": true,
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "paths": {
      "@/*": ["server/src/*"],
      "@core/*": ["shared/*"],
      "@common/*": ["server/src/shared/*"],
      "@admin/*": ["server/src/admin/*"],
      "@game/*": ["server/src/game/*"],
      "@page/*": ["server/src/page/*"],
      "@user/*": ["server/src/user/*"],
      "shared/*": ["shared/*"]
    },
    "strict": true,
    "strictNullChecks": true,
    "strictPropertyInitialization": true,
    "useUnknownInCatchVariables": false,
    "strictFunctionTypes": true,
    "noImplicitAny": false,
    "noImplicitThis": false,
    "alwaysStrict": false
  },
  "include": ["src/**/*"],
  "references": [
    {
      "path": "../shared"
    }
  ]
}
