{
  "extends": "../tsconfig.json",
  "compilerOptions": {
    "outDir": "./dist",
    "baseUrl": ".",
    "paths": {
      "@/*": ["./src/*"],
      "@core/*": ["../core/*"],
      "@common/*": ["./src/shared/*"],
      "@admin/*": ["./src/admin/*"],
      "@game/*": ["./src/game/*"],
      "@page/*": ["./src/page/*"],
      "@user/*": ["./src/user/*"]
    },
    "strict": true,
    "strictNullChecks": true,
    "strictPropertyInitialization": true,
    "useUnknownInCatchVariables": false,
    "strictFunctionTypes": true,
    "noImplicitAny": false,
    "noImplicitThis": false,
    "alwaysStrict": false
  },
  "references": [{ "path": "../core" }],
  "include": ["src/**/*"],
  "exclude": ["node_modules", "dist"]
}
