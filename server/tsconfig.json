{
  "extends": "../tsconfig.json",
  "compilerOptions": {
    "outDir": "./dist",
    "rootDir": "src",
    "baseUrl": "src",
    "paths": {
      "@/*": ["./*"],
      "@core/*": ["../../shared/*"],
      "@common/*": ["./shared/*"],
      "@admin/*": ["./admin/*"],
      "@game/*": ["./game/*"],
      "@page/*": ["./page/*"],
      "@user/*": ["./user/*"],
      "shared/*": ["../shared/*"]
    },
    "strict": true,
    "strictNullChecks": true,
    "strictPropertyInitialization": true,
    "useUnknownInCatchVariables": false,
    "strictFunctionTypes": true,
    "noImplicitAny": false,
    "noImplicitThis": false,
    "alwaysStrict": false
  },
  "references": [{ "path": "../shared" }],
  "include": ["src/**/*"],
  "exclude": ["node_modules", "dist"]
}
