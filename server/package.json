{
  "name": "ai-story-game-server",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "_moduleAliases": {
    "@core": "dist/core",
    "@common": "dist/shared",
    "@admin": "dist/admin",
    "@game": "dist/game",
    "@page": "dist/page",
    "@user": "dist/user"
  },
  "scripts": {
    "build": "cd ../core && npm install && npm run build && cd ../server && npm install && rm -rf dist && tsc && mkdir -p dist/core && cp -r ../core/dist/* dist/core/ && npx tsc-alias --project tsconfig.alias.json",
    "dev": "tsx watch src/index.ts",
    "start": "node dist/index.js"
  },
