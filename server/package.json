{
  "name": "ai-story-game-server",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "engines": {
    "node": "20.x"
  },
  "scripts": {
    "build": "cd ../core && npm install && npm run build && cd ../server && npm install && rm -rf dist && tsc --project tsconfig.json && mkdir -p dist/core && cp -r ../core/dist/* dist/core/ && npx tsc-alias && npm run debug-build",
    "dev": "tsx watch src/index.ts",
    "start": "node --es-module-specifier-resolution=node dist/index.js",
    "debug-build": "echo '\\n===== DEBUG: Server dist directory structure =====\\n' && ls -la dist && echo '\\n===== DEBUG: Core dist directory structure =====\\n' && ls -la ../core/dist && echo '\\n===== DEBUG: Server dist/core directory structure =====\\n' && ls -la dist/core && echo '\\n===== DEBUG: Sample config.js in server dist/core =====\\n' && head -20 dist/core/config.js && echo '\\n===== DEBUG: First few lines of dist/config.js =====\\n' && head -20 dist/config.js && echo '\\n===== DEBUG: Done debugging ====='",
    "lint": "eslint . && tsc --noEmit",
    "test": "set NODE_OPTIONS=--experimental-vm-modules&& jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "test:unit": "jest --testPathPattern='test\\.ts$'",
    "test:integration": "jest --testPathPattern='integration\\.ts$'",
    "test:lint": "eslint tests/ --format=stylish && npx tsc --noEmit --project tests/tsconfig.lint.json",
    "test:all": "npm test && npm run test:lint",
    "check": "npm run lint && npm run test:all",
    "check:all": "npm run lint && npm run test:all"
  },
  "keywords": [],
  "author": "Odin Mühlenbein",
  "license": "",
  "dependencies": {
    "@langchain/anthropic": "^0.3.21",
    "@langchain/core": "^0.3.68",
    "@langchain/google-genai": "^0.2.9",
    "@langchain/openai": "^0.6.7",
    "@types/cookie-parser": "^1.4.8",
    "@types/csurf": "^1.11.5",
    "@types/multer": "^1.4.12",
    "@types/node": "^20.0.0",
    "@types/sharp": "^0.32.0",
    "@types/socket.io": "^3.0.1",
    "bcrypt": "^5.1.1",
    "cookie-parser": "^1.4.7",
    "core": "file:../core",
    "cors": "^2.8.5",
    "csurf": "^1.11.0",
    "dotenv": "^16.4.7",
    "express": "^4.18.0",
    "jsonwebtoken": "^9.0.2",
    "jszip": "^3.10.1",
    "langchain": "^0.3.37",
    "multer": "^2.0.1",
    "openai": "^5.12.2",
    "pg": "^8.16.0",
    "sharp": "^0.34.2",
    "socket.io": "^4.8.1",
    "uuid": "^9.0.1",
    "ws": "^8.16.0",
    "zod": "^3.22.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.19.0",
    "@types/bcrypt": "^5.0.2",
    "@types/chai": "^4.3.20",
    "@types/cors": "^2.8.0",
    "@types/express": "^4.17.21",
    "@types/jest": "^30.0.0",
    "@types/jsonwebtoken": "^9.0.6",
    "@types/jszip": "^3.4.1",
    "@types/pg": "^8.15.2",
    "@types/uuid": "^9.0.8",
    "@types/ws": "^8.5.0",
    "eslint": "^9.31.0",
    "globals": "^15.14.0",
    "jest": "^30.0.4",
    "ts-jest": "^29.4.0",
    "tsc-alias": "^1.8.15",
    "tsx": "^4.7.1",
    "typescript": "^5.0.0",
    "typescript-eslint": "^8.22.0"
  }
}
