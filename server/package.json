    "langchain": "^0.3.15",
    "module-alias": "^2.2.3",
    "openai": "^4.83.0",
    "socket.io": "^4.8.1",
    "ws": "^8.16.0",
    "zod": "^3.22.0"
  },
  "devDependencies": {
    "@types/cors": "^2.8.0",
    "@types/express": "^4.17.21",
