{
  "compilerOptions": {
    "target": "ES2020",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "declaration": true,
    "outDir": "./dist",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "composite": true,
    "rootDir": "..",
    "baseUrl": "..",
    "paths": {
      "@core/*": ["shared/*"]
    }
  },
  "include": ["types/**/*", "utils/**/*", "models/**/*", "config.ts"],
  "exclude": ["node_modules", "dist"]
}
