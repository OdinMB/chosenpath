{
  "compilerOptions": {
    "target": "ES2020",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "declaration": true,
    "outDir": "./dist",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "composite": true,
    "rootDir": "."
  },
  "include": [
    "types/**/*",
    "utils/**/*",
    "models/**/*",
    "config.ts",
    "../backup/Story.orig.ts"
  ],
  "exclude": ["node_modules", "dist"]
}
